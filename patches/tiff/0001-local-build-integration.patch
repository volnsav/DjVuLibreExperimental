 set(LERC_SUPPORT FALSE)
 set(LERC_STATIC FALSE)
-find_package(LERC)
+find_package(LERC NAMES unofficial-lerc)
+if(TARGET unofficial::Lerc::Lerc)
+    add_library(LERC::LERC ALIAS unofficial::Lerc::Lerc)
+endif()
